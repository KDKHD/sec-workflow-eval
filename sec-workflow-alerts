print(f\"  enabled={d.get('enabled')} from={d.get('from')}\")
"

kibana_curl -X POST "$KIBANA_URL/internal/alerting/rule/$INSIGHTS_RULE_ID/_run_soon" > /dev/null 2>&1 || true
echo "  Triggered rule, waiting ${WAIT_SECS}s for execution..."
