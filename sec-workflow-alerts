#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Defaults (override via flags or env vars) ───────────────────────────
EVENTS=20
HOSTS=2
USERS=2
EPISODES="noise1"
START_DATE="1d"
END_DATE="now"
WORKFLOW_ID="workflow-3cf6d7f4-864f-4722-834d-ae1743f445ea"
LOOKBACK="now-2d"
INSIGHTS_RULE_ID_STATIC="61e90241-c8f2-47bc-8e47-238420a34fb6"
WAIT_SECS=20
FIXTURES_FILE="$SCRIPT_DIR/fixtures/alerts.json"

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Automates: delete alerts → create rules → set workflow action → index episode
data → trigger rule with extended lookback so workflow actions fire.

Standalone: no Kibana repo required.

Options:
  -n, --events NUM        Number of source events (default: $EVENTS)
  --hosts NUM             Number of hosts (default: $HOSTS)
  -u, --users NUM         Number of users (default: $USERS)
  --episodes IDS          Comma-separated episode IDs (default: $EPISODES)
  --start-date DATE       Date math start (default: $START_DATE)
  --end-date DATE         Date math end (default: $END_DATE)
  --workflow-id ID        Workflow ID for rule action (default: $WORKFLOW_ID)
  --lookback EXPR         Rule lookback expression (default: $LOOKBACK)
  --wait SECS             Seconds to wait for rule execution (default: $WAIT_SECS)
  --fixtures FILE         Path to alerts JSON file (default: fixtures/alerts.json)
  --es-url URL            Override Elasticsearch URL (or set ES_URL env var)
  --help                  Show this help
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--events)   EVENTS="$2"; shift 2 ;;
    --hosts)       HOSTS="$2"; shift 2 ;;
    -u|--users)    USERS="$2"; shift 2 ;;
    --episodes)    EPISODES="$2"; shift 2 ;;
    --start-date)  START_DATE="$2"; shift 2 ;;
    --end-date)    END_DATE="$2"; shift 2 ;;
    --workflow-id) WORKFLOW_ID="$2"; shift 2 ;;
    --lookback)    LOOKBACK="$2"; shift 2 ;;
    --wait)        WAIT_SECS="$2"; shift 2 ;;
    --fixtures)    FIXTURES_FILE="$2"; shift 2 ;;
    --es-url)      ES_URL="$2"; shift 2 ;;
    -h|--help)     usage ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

# ── Inline: Kibana connection detection ─────────────────────────────────
KIBANA_URL="${KIBANA_URL:-}"
KIBANA_AUTH="${KIBANA_AUTH:-}"

_try_kibana() {
  local url="$1" auth="$2" http_code
  http_code="$(curl -s -o /dev/null -w "%{http_code}" -k "$url/api/status" 2>/dev/null || echo "000")"
  [[ "$http_code" == "000" ]] && return 1
  http_code="$(curl -s -o /dev/null -w "%{http_code}" -k -u "$auth" \
    -H "kbn-xsrf: true" -H "x-elastic-internal-origin: Kibana" \
    "$url/api/data_sources" 2>/dev/null || echo "000")"
  [[ "$http_code" != "000" && "$http_code" != "401" ]]
}

detect_kibana() {
  local _URLS=("http://localhost:5601" "https://localhost:5601")
  local _AUTHS=("elastic:changeme" "elastic_serverless:changeme")

  if [[ -n "$KIBANA_URL" && -n "$KIBANA_AUTH" ]]; then
    _try_kibana "$KIBANA_URL" "$KIBANA_AUTH" && return 0
    echo "Warning: Provided KIBANA_URL=$KIBANA_URL did not respond. Falling back to auto-detection." >&2
    KIBANA_URL="" KIBANA_AUTH=""
  fi

  if [[ -n "$KIBANA_URL" ]]; then
    for auth in "${_AUTHS[@]}"; do
      if _try_kibana "$KIBANA_URL" "$auth"; then
        KIBANA_AUTH="$auth"; return 0
      fi
    done
    echo "Error: Kibana at $KIBANA_URL did not respond with any known credentials." >&2
    return 1
  fi

  for url in "${_URLS[@]}"; do
    for auth in "${_AUTHS[@]}"; do
      if _try_kibana "$url" "$auth"; then
        KIBANA_URL="$url" KIBANA_AUTH="$auth"
        echo "Detected Kibana at $KIBANA_URL (auth: ${auth%%:*})" >&2
        return 0
      fi
    done
  done

  echo "Error: Could not detect a running Kibana instance." >&2
  echo "Please ensure Kibana is running, or set KIBANA_URL and KIBANA_AUTH explicitly." >&2
  return 1
}

kibana_curl() {
  local tls_flag=""
  [[ "$KIBANA_URL" == https://* ]] && tls_flag="-k"
  curl -s $tls_flag -u "$KIBANA_AUTH" \
    -H "kbn-xsrf: true" \
    -H "x-elastic-internal-origin: Kibana" \
    "$@"
}

detect_kibana
ES_URL="${ES_URL:-${KIBANA_URL/5601/9200}}"

es_curl() {
  local tls_flag=""
  [[ "$ES_URL" == https://* ]] && tls_flag="-k"
  curl -s $tls_flag -u "$KIBANA_AUTH" "$@"
}

step() {
