# ── Step 4: Index alerts from fixtures file ─────────────────────────────
step "4/5  Indexing alerts (50% noise / 50% attack, N=$EVENTS, fixtures=$(basename "$FIXTURES_FILE"))"

_SEC_ES_URL="$ES_URL" \
_SEC_KIBANA_AUTH="$KIBANA_AUTH" \
_SEC_START_DATE="$START_DATE" \
_SEC_END_DATE="$END_DATE" \
_SEC_EVENTS="$EVENTS" \
_SEC_HOSTS="$HOSTS" \
_SEC_USERS="$USERS" \
_SEC_FIXTURES_FILE="$FIXTURES_FILE" \
python3 - <<'PYEOF'
import json, sys, hashlib, copy, os, base64, ssl
import urllib.request, urllib.error
from datetime import datetime, timezone, timedelta
import re

_SSL_CTX = ssl.create_default_context()
_SSL_CTX.check_hostname = False
_SSL_CTX.verify_mode = ssl.CERT_NONE

# ── Connection ───────────────────────────────────────────────────────────
ES_URL         = os.environ['_SEC_ES_URL']
KIBANA_AUTH    = os.environ['_SEC_KIBANA_AUTH']
ES_USER, ES_PASS = KIBANA_AUTH.split(':', 1)
START_DATE_ARG = os.environ['_SEC_START_DATE']
END_DATE_ARG   = os.environ['_SEC_END_DATE']
TARGET_EVENTS  = int(os.environ['_SEC_EVENTS'])
HOST_COUNT     = int(os.environ['_SEC_HOSTS'])
USER_COUNT     = int(os.environ['_SEC_USERS'])
FIXTURES_FILE  = os.environ['_SEC_FIXTURES_FILE']

# ── Load fixtures ────────────────────────────────────────────────────────
# Flat JSON array of alert docs.
# odd  kibana.alert.risk_score  →  noise pool   (false positives)
# even kibana.alert.risk_score  →  attack pool  (true positives)
if not os.path.isfile(FIXTURES_FILE):
    print(f"ERROR: fixtures file not found: {FIXTURES_FILE}", file=sys.stderr)
    print("Place your alerts.json in the fixtures/ directory, or pass --fixtures <path>.", file=sys.stderr)
    sys.exit(1)

with open(FIXTURES_FILE) as f:
    all_alerts = json.load(f)

def _risk_score(doc):
    return doc.get('kibana.alert.risk_score', doc.get('event', {}).get('risk_score', 0))

noise_pool  = [doc for doc in all_alerts if int(_risk_score(doc)) % 2 == 1]   # odd  → FP
attack_pool = [doc for doc in all_alerts if int(_risk_score(doc)) % 2 == 0]   # even → TP

if not noise_pool and not attack_pool:
    print("ERROR: no docs in fixtures", file=sys.stderr)
    sys.exit(1)

# ── Date math ────────────────────────────────────────────────────────────
UNITS = {'s': 1, 'm': 60, 'h': 3600, 'd': 86400, 'w': 604800}

def parse_date_math(expr, now_ms=None):
    if now_ms is None:
        now_ms = int(datetime.now(timezone.utc).timestamp() * 1000)
    if expr == 'now':
        return now_ms
    m = re.match(r'^(\d+)([smhdw])$', expr)
    if m:
        return now_ms - int(m.group(1)) * UNITS[m.group(2)] * 1000
    m = re.match(r'^now([+-])(\d+)([smhdw])$', expr)
    if m:
        sign = 1 if m.group(1) == '+' else -1
        return now_ms + sign * int(m.group(2)) * UNITS[m.group(3)] * 1000
    raise ValueError(f"Cannot parse date math: {expr}")

# ── Deterministic helpers ────────────────────────────────────────────────
HOST_WORDS = ['alpha','bravo','charlie','delta','echo','foxtrot','golf','hotel',
              'india','juliet','kilo','lima','mike','november','oscar','papa']
USER_WORDS = ['alice','bob','charlie','diana','eve','frank','grace','henry',
              'iris','jack','karen','leo','mary','nina','oscar','pete']

def _hash_int(s):
    return int(hashlib.sha256(s.encode()).hexdigest()[:8], 16)

def gen_name(words, seed, idx):
    n = _hash_int(f'{seed}:{idx}') % len(words)
    suffix = (_hash_int(f'{seed}:{idx}:s') % 99) + 1
    return f"{words[n]}-{suffix}"

# ── Timestamp helpers ────────────────────────────────────────────────────
def _shift_iso(iso, delta_ms):
    try:
        ts = datetime.fromisoformat(iso.replace('Z', '+00:00'))
        new_ts = ts + timedelta(milliseconds=delta_ms)
        return new_ts.strftime('%Y-%m-%dT%H:%M:%S.') + f"{new_ts.microsecond // 1000:03d}Z"
    except Exception:
        return iso

def _get_nested(d, path):
    for k in path:
        if not isinstance(d, dict): return None
        d = d.get(k)
    return d

def _set_nested(d, path, val):
    for k in path[:-1]:
        d = d.setdefault(k, {})
    d[path[-1]] = val

NESTED_TS = [['event','created'],['event','ingested'],['event','start'],['event','end']]

def shift_timestamps(doc, delta_ms):
    if '@timestamp' in doc:
        doc['@timestamp'] = _shift_iso(doc['@timestamp'], delta_ms)
    for path in NESTED_TS:
        v = _get_nested(doc, path)
        if isinstance(v, str):
            _set_nested(doc, path, _shift_iso(v, delta_ms))
    ts = doc.get('@timestamp')
    if isinstance(ts, str):
        _set_nested(doc, ['event','created'], ts)
        _set_nested(doc, ['event','ingested'], _shift_iso(ts, 1000))

def set_host_user(doc, host, user, host_id, agent_id):
    for path, val in [
        (['host','name'], host), (['host','hostname'], host), (['host','id'], host_id),
        (['agent','id'], agent_id), (['elastic','agent','id'], agent_id), (['user','name'], user),
    ]:
        _set_nested(doc, path, val)

def doc_ts_ms(doc):
    return int(datetime.fromisoformat(doc['@timestamp'].replace('Z','+00:00')).timestamp() * 1000)

# ── ES bulk index ────────────────────────────────────────────────────────
def bulk_index(index, docs):
    if not docs:
        return 0
    lines = []
    for doc in docs:
        lines.append(json.dumps({'index': {'_index': index}}))
        lines.append(json.dumps(doc))
    body = ('\n'.join(lines) + '\n').encode()
    creds = base64.b64encode(f"{ES_USER}:{ES_PASS}".encode()).decode()
    req = urllib.request.Request(
        ES_URL.rstrip('/') + '/_bulk', data=body,
        headers={'Authorization': f'Basic {creds}', 'Content-Type': 'application/x-ndjson'},
        method='POST',
    )
    try:
        with urllib.request.urlopen(req, context=_SSL_CTX) as resp:
            result = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        result = json.loads(e.read())
    errs = [i for i in result.get('items', []) if list(i.values())[0].get('error')]
    if errs:
        print(f"  warn: {len(errs)} bulk errors in {index}", file=sys.stderr)
    return len(docs)

# ── Main ─────────────────────────────────────────────────────────────────
def run():
    now_ms   = int(datetime.now(timezone.utc).timestamp() * 1000)
    start_ms = parse_date_math(START_DATE_ARG, now_ms)
    end_ms   = parse_date_math(END_DATE_ARG, now_ms)
    if end_ms <= start_ms:
        end_ms   = now_ms
        start_ms = now_ms - 86400 * 1000

    range_ms = end_ms - start_ms
    date_str = datetime.fromtimestamp(end_ms / 1000, tz=timezone.utc).strftime('%Y.%m.%d')

    hosts = [gen_name(HOST_WORDS, 'host', i) for i in range(HOST_COUNT)]
    users = [gen_name(USER_WORDS, 'user', i) for i in range(USER_COUNT)]
    risky_hosts = hosts[:max(1, HOST_COUNT // 2)]
    risky_users = users[:max(1, USER_COUNT // 2)]

    if noise_pool and attack_pool:
        noise_count  = TARGET_EVENTS // 2
        attack_count = TARGET_EVENTS - noise_count
    elif noise_pool:
        noise_count  = TARGET_EVENTS
        attack_count = 0
    else:
        noise_count  = 0
        attack_count = TARGET_EVENTS

    print(f"  Fixtures: {FIXTURES_FILE}")
    print(f"  Noise  alerts (FP, odd risk):  {noise_count}  (pool: {len(noise_pool)} unique)")
    print(f"  Attack alerts (TP, even risk): {attack_count}  (pool: {len(attack_pool)} unique)")
    if noise_count and noise_count > len(noise_pool):
        print(f"  note: {noise_count - len(noise_pool)} noise doc(s) will repeat")
    if attack_count and attack_count > len(attack_pool):
        print(f"  note: {attack_count - len(attack_pool)} attack doc(s) will repeat")

    index_buffers = {}

    def place_docs(pool, count, label, use_risky):
        for i in range(count):
            doc = copy.deepcopy(pool[i % len(pool)])
            ts_ms    = start_ms + int(range_ms * i / max(count, 1))
            delta_ms = ts_ms - doc_ts_ms(doc)
            shift_timestamps(doc, delta_ms)

            h_pool = risky_hosts if use_risky else hosts
            u_pool = risky_users if use_risky else users
            host = h_pool[_hash_int(f'{label}:{i}:h') % len(h_pool)]
            user = u_pool[_hash_int(f'{label}:{i}:u') % len(u_pool)]
            set_host_user(doc, host, user,
                          f"host-{_hash_int(host):016x}",
                          f"agent-{_hash_int(host+user):016x}")

            index_buffers.setdefault(f"insights-alerts-{label}-{date_str}", []).append(doc)

    if noise_count:
        place_docs(noise_pool,  noise_count,  'noise',   use_risky=False)
    if attack_count:
        place_docs(attack_pool, attack_count, 'attacks', use_risky=True)

    total = 0
    for index, docs in sorted(index_buffers.items()):
        n = bulk_index(index, docs)
        total += n
        print(f"  Indexed {n} docs into {index}")

    print(f"  Done — {total} total docs indexed")

run()
PYEOF

echo ""
echo "  Source data:"
es_curl "$ES_URL/_cat/indices/insights-alerts-*?h=index,docs.count" 2>/dev/null | grep -v ' 0$' | sed 's/^/    /' || true

